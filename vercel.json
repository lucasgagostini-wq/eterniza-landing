{
  "functions": {
    "api/preview.js": { "maxDuration": 60 }
  },
  "redirects": [
    { "source": "/homenagem.html", "destination": "/homenagem", "permanent": false },
    { "source": "/encontro", "destination": "/encontro/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/homenagem", "destination": "/homenagem.html" },
    { "source": "/privacidade", "destination": "/privacidade.html" },
    { "source": "/termos", "destination": "/termos.html" },
    { "source": "/encontro/", "destination": "https://eterniza-funnel.vercel.app/" },
    { "source": "/encontro/:path*", "destination": "https://eterniza-funnel.vercel.app/:path*" }
  ]
}
